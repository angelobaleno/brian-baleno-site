---
import { site } from '../data/site.ts';
import { withBase } from '../lib/url.ts';
---
<section class="section section--alt about" id="about">
  <div class="container about__inner">
    <div class="about__photo" data-reveal>
      <img src={withBase(site.headshot)} alt={`Portrait of author ${site.name}`} width="370" height="420" loading="lazy" decoding="async" />
    </div>
    <div class="about__body" data-reveal>
      <p class="kicker">About the Author</p>
      <h2>{site.name}</h2>
      {site.bio.map((para, i) => (
        <p class:list={['about__para', { 'about__para--first': i === 0 }]} set:html={para} />
      ))}
      <p class="endmark" aria-hidden="true">&#10087;</p>
    </div>
  </div>
</section>

<style>
  .about__inner { display: grid; grid-template-columns: 320px 1fr; gap: 54px; align-items: center; }
  /* isolate: keeps the z-index:-1 frame above the section background. */
  .about__photo { position: relative; isolation: isolate; }
  .about__photo::after {
    content: "";
    position: absolute;
    inset: 16px -16px -16px 16px;
    border: 1px solid var(--gold);
    border-radius: 4px;
    z-index: -1;
  }
  /* Flat, print-like plate: no web shadow, just an offset hairline frame. */
  .about__photo img {
    border-radius: 4px;
    width: 100%; height: auto;
    filter: saturate(0.94) sepia(0.06);
  }
  .about__para { font-size: 1.12rem; color: var(--ink-soft); margin: 0 0 1em; max-width: 60ch; }
  .about__para :global(em) { font-style: italic; }
  /* A quiet drop cap opens the author's own story. */
  .about__para--first::first-letter {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    font-size: 3.1em;
    float: left;
    line-height: 0.82;
    padding: 4px 10px 0 0;
    color: var(--ink);
  }
  @media (max-width: 760px) {
    .about__inner { grid-template-columns: 1fr; justify-items: center; gap: 36px; }
    .about__photo { max-width: 260px; }
    .about__body { text-align: left; }
    .about__body .kicker, .about__body h2 { text-align: center; }
    .about__body .endmark { text-align: center; }
  }
</style>
