---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';
import { withBase } from '../lib/url.ts';

interface Props {
  title: string;
  description?: string;
  /** Site-relative path (e.g. a book cover) used for social cards. */
  image?: string;
}
const {
  title,
  description = 'Novels and memoirs by author Brian Baleno.',
  image = site.headshot,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(withBase(image), Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#f5efe4" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="sitemap" href={withBase('/sitemap.xml')} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=EB+Garamond:ital,wght@0,400;1,400&family=Archivo:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <noscript>
      <style>[data-reveal] { opacity: 1 !important; transform: none !important; }</style>
    </noscript>
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      // Restrained scroll reveal. Elements that enter the viewport in the same
      // observer batch cascade in reading order instead of appearing at once.
      const io = new IntersectionObserver(
        (entries) => {
          let i = 0;
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            (e.target as HTMLElement).style.setProperty('--reveal-delay', `${Math.min(i * 80, 320)}ms`);
            e.target.classList.add('in-view');
            io.unobserve(e.target);
            i++;
          }
        },
        { threshold: 0.14 }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
